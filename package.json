{
    "name": "username-extractor",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "vite dev --open",
        "benchmark": "bun scripts/benchmark.ts",
        "build": "vite build && node scripts/wrap-worker.mjs",
        "preview": "bun run build && wrangler dev",
        "deploy": "bun run build && wrangler deploy",
        "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
        "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
        "format": "prettier --write .",
        "lint": "prettier --check . && eslint .",
        "sync-ds": "rsync -a --delete ../../dropout-design-system/src/lib/ ./src/lib/ds/",
        "test": "vitest run",
        "test:watch": "vitest",
        "cf-typegen": "wrangler types",
        "db:generate": "drizzle-kit generate",
        "db:push": "drizzle-kit push",
        "db:studio": "drizzle-kit studio",
        "db:check": "drizzle-kit check",
        "db:migrate": "wrangler d1 migrations apply username-extractor --remote",
        "db:migrate:local": "wrangler d1 migrations apply username-extractor --local",
        "db:migrate:list": "wrangler d1 migrations list username-extractor --local"
    },
    "devDependencies": {
        "@cloudflare/workers-types": "^4.20260625.1",
        "@eslint/compat": "^2.1.0",
        "@eslint/js": "^10.0.1",
        "@sveltejs/adapter-cloudflare": "^7.2.9",
        "@sveltejs/enhanced-img": "^0.11.0",
        "@sveltejs/kit": "^2.68.0",
        "@sveltejs/vite-plugin-svelte": "^7.1.2",
        "@tailwindcss/vite": "^4.3.1",
        "@types/node": "^26.0.1",
        "drizzle-kit": "0.31.10",
        "eslint": "^10.5.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-svelte": "^3.19.0",
        "globals": "^17.7.0",
        "prettier": "^3.8.4",
        "prettier-plugin-svelte": "^4.1.1",
        "prettier-plugin-tailwindcss": "^0.8.0",
        "svelte": "5.56.4",
        "svelte-check": "^4.7.1",
        "tailwindcss": "^4.3.1",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.62.0",
        "vite": "^8.1.0",
        "vite-plugin-devtools-json": "^1.0.0",
        "vitest": "^4.1.9",
        "wrangler": "^4.105.0"
    },
    "dependencies": {
        "@better-auth/passkey": "1.6.20",
        "@lucide/svelte": "^1.21.0",
        "@notionhq/client": "^5.22.0",
        "@unpic/svelte": "^1.0.1",
        "better-auth": "^1.6.20",
        "bits-ui": "^2.18.1",
        "clsx": "^2.1.1",
        "drizzle-orm": "^0.45.2",
        "formsnap": "^2.0.1",
        "mode-watcher": "^1.1.0",
        "svelte-sonner": "^1.1.1",
        "sveltekit-superforms": "^2.30.1",
        "tailwind-merge": "^3.6.0",
        "tailwind-variants": "^3.2.2",
        "tw-animate-css": "^1.4.0",
        "zod": "^4.4.3"
    }
}
